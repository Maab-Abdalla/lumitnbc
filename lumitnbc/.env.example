# LumiTNBC environment variables

# Required in production: a long random string for session security
SECRET_KEY=change-me-to-a-long-random-string

# Set automatically by Railway's Postgres add-on. Leave unset locally to use SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: force the config. Auto-detects (production if DATABASE_URL is set).
# FLASK_ENV=production


# Optional: enables the LLM features (chatbot + personal summary), both Anthropic.
# Unset = chatbot uses the offline keyword bot and the summary card is hidden.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the chat model (default claude-haiku-4-5-20251001).
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
